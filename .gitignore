# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dependencies
node_modules/

# TypeScript build output (regenerated by `npm run prepublishOnly`)
lib/
*.tsbuildinfo

# Generated nitrogen output is COMMITTED — do not ignore /nitrogen/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Env
.env
.env.local
.env.*.local

# Native build artifacts (library side — example has its own .gitignore)
android/.gradle/
android/.kotlin/
android/build/
android/.cxx/
android/local.properties
android/.idea/
android/*.iml
android/captures/

# CocoaPods / iOS (future-proof)
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# Packaging output
*.tgz
