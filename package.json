{
  "name": "react-native-nitro-rtmp-publisher",
  "version": "0.10.6",
  "description": "RTMP/RTMPS live streaming camera for React Native (iOS, Android, Expo). Hardware-accelerated H.264/HEVC, adaptive bitrate, auto-reconnect. Stream to YouTube Live, Facebook Live, Twitch, Instagram.",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "ios",
    "NitroRtmpPublisher.podspec",
    "podspecs",
    "app.plugin.js",
    "plugin",
    "nitro.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typescript": "tsc",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\"",
    "prepublishOnly": "rm -rf lib tsconfig.tsbuildinfo && tsc && nitrogen"
  },
  "keywords": [
    "react-native",
    "react-native-nitro-modules",
    "nitro-module",
    "nitro-modules",
    "fabric",
    "new-architecture",
    "expo",
    "expo-plugin",
    "rtmp",
    "rtmps",
    "rtmp-publisher",
    "rtmp-streaming",
    "rtmp-server",
    "live-streaming",
    "live-stream",
    "livestream",
    "streaming",
    "streaming-sdk",
    "video-streaming",
    "broadcasting",
    "broadcaster",
    "broadcast",
    "camera",
    "camera-streaming",
    "video",
    "h264",
    "hevc",
    "h265",
    "aac",
    "adaptive-bitrate",
    "auto-reconnect",
    "facebook-live",
    "youtube-live",
    "twitch",
    "instagram-live",
    "wowza",
    "nimble",
    "rootencoder",
    "haishinkit",
    "videotoolbox",
    "mediacodec",
    "android",
    "ios"
  ],
  "license": "MIT",
  "author": "fluxlabs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fluxlabs-tech/react-native-nitro-rtmp-publisher.git"
