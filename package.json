  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@expo/config-plugins": "^54.0.4",
    "@types/react": "^19.1.0",
    "nitrogen": "*",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "*",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  }
}
