<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!--
    Alternate manifest used when the consumer opts out of foreground-service
    support via `nitroRtmpPublisherFgs=false` in their gradle.properties.

    What's intentionally omitted relative to the default AndroidManifest.xml:
      - FOREGROUND_SERVICE (+ CAMERA / MICROPHONE variants)
      - POST_NOTIFICATIONS
      - The <service> declaration for RtmpForegroundService

    Net effect for the consumer's merged APK:
      - No Play Console "Foreground services" declaration form required
      - Stream is foreground-only — camera/mic die when the app backgrounds
        (Android 14+ revokes capture without an active FG service of the
        correct type)
      - foregroundServiceTitle / foregroundServiceText / foregroundServiceIcon
        props become no-ops; library logs a one-time warning when JS supplies
        a non-empty title.

    The compiled RtmpForegroundService class is still in the AAR (dead code
    without a manifest declaration); ~3 KB. Splitting that out would require
    two AAR artifacts which is overkill for the size win.
  -->

  <uses-permission android:name="android.permission.CAMERA" />
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <uses-feature android:name="android.hardware.camera" android:required="false" />
  <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
  <uses-feature android:name="android.hardware.microphone" android:required="false" />
</manifest>
